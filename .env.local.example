NEXT_PUBLIC_SITE_NAME=Popout Web

# Browser Supabase (same as Expo app). Use either pair — Expo names are mapped in next.config.ts.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
# NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Market feed (defaults match a typical Popout schema)
# Table `posts` + join `suburbs` on suburb_id; only rows with allowed status are shown.
# NEXT_PUBLIC_SUPABASE_MARKET_TABLE=posts
# Optional — must match enum `post_status` exactly (e.g. listed, published). If unset, no status filter (use RLS).
# NEXT_PUBLIC_SUPABASE_POST_STATUSES=listed
# Map picker → posts.suburb_id (int). Southbank=703 is set in lib/market-suburb-ids.ts; fill the rest from SQL:
#   select id, name from public.suburbs order by name;
# Or one-line JSON override (keys must match picker text exactly):
# NEXT_PUBLIC_MARKET_SUBURB_IDS={"Melbourne CBD":100,"Carlton":200,"Parkville":300,"Southbank":703,"Docklands":400,"Fitzory":500,"North Melbourne":600,"South Wharf":700}
# Post thumbnails — default `post_images` (same as Expo src/lib/storage.ts). Override if different:
# NEXT_PUBLIC_SUPABASE_MARKET_IMAGES_BUCKET=post_images
# Legacy flat demo table only:
# NEXT_PUBLIC_SUPABASE_MARKET_TABLE=web_market_posts

# Footer social profile URLs (optional — Xiaohongshu/LinkedIn have defaults in code; must be https).
# NEXT_PUBLIC_FOOTER_SOCIAL_REDNOTE_URL=https://example.com
# NEXT_PUBLIC_FOOTER_SOCIAL_INSTAGRAM_URL=https://www.instagram.com/yourprofile
# LinkedIn defaults to the company link in code; set this to override (e.g. public page without /admin/).
# NEXT_PUBLIC_FOOTER_SOCIAL_LINKEDIN_URL=https://www.linkedin.com/company/112766074/

# Server-only (never commit real keys). Not used by the Market page yet.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
